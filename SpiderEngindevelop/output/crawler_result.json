{
  "item": [
    {
      "sentence": "若使当时身不遇，老了英雄。",
      "source": "王安石《浪淘沙令·伊吕两衰翁》",
      "href": "\/mingju\/juv_68abba451877.aspx"
    },
    {
      "sentence": "洛阳愁绝，杨柳花飘雪。",
      "source": "温庭筠《清平乐·洛阳愁绝》",
      "href": "\/mingju\/juv_44767262c811.aspx"
    },
    {
      "sentence": "秋色渐将晚，霜信报黄花。",
      "source": "叶梦得《水调歌头·秋色渐将晚》",
      "href": "\/mingju\/juv_3856ec246eea.aspx"
    },
    {
      "sentence": "夫妻本是同林鸟，巴到天明各自飞。",
      "source": "《警世通·卷二》",
      "href": "\/mingju\/juv_72ada2709008.aspx"
    },
    {
      "sentence": "涵养冲虚，便是身世学问。省除烦恼，何等心性安和！",
      "source": "《格言联璧·存养类》",
      "href": "\/mingju\/juv_581f1a13730b.aspx"
    },
    {
      "sentence": "细数落花因坐久，缓寻芳草得归迟。",
      "source": "王安石《北山》",
      "href": "\/mingju\/juv_f40e8046ee35.aspx"
    },
    {
      "sentence": "修身岂为名传世，做事唯思利及人。",
      "source": "",
      "href": "\/mingju\/juv_0220999983df.aspx"
    },
    {
      "sentence": "无欲速，无见小利。欲速则不达，见小利则大事不成。",
      "source": "《论语·子路篇》",
      "href": "\/mingju\/juv_5886952db370.aspx"
    },
    {
      "sentence": "水绕陂田竹绕篱，榆钱落尽槿花稀。",
      "source": "张舜民《村居·水绕陂田竹绕篱》",
      "href": "\/mingju\/juv_507bf9bfb851.aspx"
    },
    {
      "sentence": "可爱一天风物，遍倚阑干十二，宇宙若萍浮。",
      "source": "米芾《水调歌头·中秋》",
      "href": "\/mingju\/juv_a5474ee8397f.aspx"
    },
    {
      "sentence": "山路元无雨，空翠湿人衣。",
      "source": "王维《山中》",
      "href": "\/mingju\/juv_729a17248b61.aspx"
    },
    {
      "sentence": "人在世间爱欲之中，独生独死，独去独来，当行至趣苦乐之地，身自当之，无有代者。",
      "source": "《无量寿经·卷下》",
      "href": "\/mingju\/juv_6117afb1f6cb.aspx"
    },
    {
      "sentence": "嘉会寄诗以亲，离群讬诗以怨。",
      "source": "佚名《古代文论选段》",
      "href": "\/mingju\/juv_f511ca193073.aspx"
    },
    {
      "sentence": "名进而身退，天之道也。",
      "source": "《管子·白心第三十八》",
      "href": "\/mingju\/juv_83a302609b98.aspx"
    },
    {
      "sentence": "尝射于家圃，有卖油翁释担而立，睨之久而不去。",
      "source": "欧阳修《卖油翁》",
      "href": "\/mingju\/juv_f71e48054a22.aspx"
    },
    {
      "sentence": "事在四方，要在中央。",
      "source": "《韩非子·扬权》",
      "href": "\/mingju\/juv_aaeb9648e299.aspx"
    },
    {
      "sentence": "日暮待情人，维舟绿杨岸。",
      "source": "储光羲《钓鱼湾》",
      "href": "\/mingju\/juv_18f39174cc82.aspx"
    },
    {
      "sentence": "养其小者为小人，养其大者为大人。",
      "source": "《孟子·告子章句上·第十四节》",
      "href": "\/mingju\/juv_44677988cb4c.aspx"
    },
    {
      "sentence": "水性虽能流不导则不通，人性虽能智不教则不达。",
      "source": "",
      "href": "\/mingju\/juv_f5225fae2f8d.aspx"
    },
    {
      "sentence": "福轻乎羽，莫之知载；祸重乎地，莫之知避。",
      "source": "《庄子·内篇·人间世》",
      "href": "\/mingju\/juv_8cc9cdb9d853.aspx"
    },
    {
      "sentence": "一诺千金重。",
      "source": "贺铸《六州歌头·少年侠气》",
      "href": "\/mingju\/juv_612e5ac43348.aspx"
    },
    {
      "sentence": "三人成虎，十夫楺椎。",
      "source": "《战国策·秦三·秦攻邯郸》",
      "href": "\/mingju\/juv_05f73fb3bee3.aspx"
    },
    {
      "sentence": "巽甫虽安之，如某歉何。临别，赋【沁园春】以饯。",
      "source": "李曾伯《沁园春·送李御带珙》",
      "href": "\/mingju\/juv_29d6b6fd47b0.aspx"
    },
    {
      "sentence": "何世无才，患人不能识之耳",
      "source": "《资治通鉴·汉纪·汉纪十一》",
      "href": "\/mingju\/juv_9643a0906a27.aspx"
    },
    {
      "sentence": "利天下之民者莫大于治",
      "source": "《商君书·开塞》",
      "href": "\/mingju\/juv_1bba85bc55b1.aspx"
    },
    {
      "sentence": "飞湍瀑流争喧豗，砯崖转石万壑雷。",
      "source": "李白《蜀道难》",
      "href": "\/mingju\/juv_480800551f92.aspx"
    },
    {
      "sentence": "满城烟水月微茫，人倚兰舟唱。",
      "source": "杨果《小桃红·满城烟水月微茫》",
      "href": "\/mingju\/juv_2b05b374e82f.aspx"
    },
    {
      "sentence": "想铁甲重瞳，乌骓汗血，玉帐连空。",
      "source": "萨都剌《木兰花慢·彭城怀古》",
      "href": "\/mingju\/juv_6d9dac0b3a19.aspx"
    },
    {
      "sentence": "君情与妾意，各自东西流。",
      "source": "李白《妾薄命》",
      "href": "\/mingju\/juv_b462da49c5b5.aspx"
    },
    {
      "sentence": "但觉衣裳湿，无点亦无声。",
      "source": "白居易《微雨夜行》",
      "href": "\/mingju\/juv_646b93227538.aspx"
    },
    {
      "sentence": "一方黑照三方紫，黄河冰合鱼龙死。",
      "source": "李贺《北中寒》",
      "href": "\/mingju\/juv_846f27f04adc.aspx"
    },
    {
      "sentence": "杳杳天低鹘没处，青山一发是中原。",
      "source": "苏轼《澄迈驿通潮阁二首》",
      "href": "\/mingju\/juv_63777ab8a582.aspx"
    },
    {
      "sentence": "指冷玉笙寒，吹彻小梅春透。",
      "source": "秦观《如梦令·春景》",
      "href": "\/mingju\/juv_5ae0a24ed1d9.aspx"
    },
    {
      "sentence": "青山横北郭，白水绕东城。",
      "source": "李白《送友人》",
      "href": "\/mingju\/juv_0d8d42fdeeed.aspx"
    },
    {
      "sentence": "云深山坞，烟冷江皋，人生未易相逢。",
      "source": "吴文英《声声慢·友人以梅兰瑞香水仙供客曰四香分韵得风字》",
      "href": "\/mingju\/juv_94ce5de29a11.aspx"
    },
    {
      "sentence": "须知入骨难销处，莫比人间取次愁。",
      "source": "徐夤《恨》",
      "href": "\/mingju\/juv_7e68e3a79fd5.aspx"
    },
    {
      "sentence": "始臣之解牛之时，所见无非牛者。三年之后，未尝见全牛也。方今之时，臣以神遇而不以目视，官知止而神欲行。",
      "source": "庄周《庖丁解牛》",
      "href": "\/mingju\/juv_c7c123dfd1dd.aspx"
    },
    {
      "sentence": "花似雪，东风夜扫苏堤月。",
      "source": "方以智《忆秦娥·花似雪》",
      "href": "\/mingju\/juv_53ab69ad7e28.aspx"
    },
    {
      "sentence": "良药苦口利于病，忠言逆耳利于行。",
      "source": "《元史·列传·卷五十五》",
      "href": "\/mingju\/juv_b21a7d57f04a.aspx"
    },
    {
      "sentence": "孤村到晓犹灯火，知有人家夜读书。",
      "source": "晃冲之《夜行》",
      "href": "\/mingju\/juv_d0dd87b662bb.aspx"
    },
    {
      "sentence": "桃花嫣然出篱笑，似开未开最有情。",
      "source": "汪藻《春日·一春略无十日晴》",
      "href": "\/mingju\/juv_533a14a074af.aspx"
    },
    {
      "sentence": "银字笙调，心字香烧。",
      "source": "蒋捷《一剪梅·舟过吴江》",
      "href": "\/mingju\/juv_29c811d0958c.aspx"
    },
    {
      "sentence": "淮上有秋山。",
      "source": "韦应物《淮上喜会梁川故人 \/ 淮上喜会梁州故人》",
      "href": "\/mingju\/juv_b5c03bbb21ee.aspx"
    },
    {
      "sentence": "自伯之东，首如飞蓬。",
      "source": "佚名《伯兮》",
      "href": "\/mingju\/juv_ac87d4c5fb34.aspx"
    },
    {
      "sentence": "天不可预虑兮，道不可预谋；迟速有命兮，焉识其时。",
      "source": "贾谊《鵩鸟赋》",
      "href": "\/mingju\/juv_11677ddf7c40.aspx"
    },
    {
      "sentence": "除却天边月，没人知。",
      "source": "韦庄《女冠子·四月十七》",
      "href": "\/mingju\/juv_756c765bc8bd.aspx"
    },
    {
      "sentence": "凡出军行师，或遇沮泽、圮毁之地，宜倍道兼行速过，不可稽留也。",
      "source": "《百战奇略·第四卷·泽战》",
      "href": "\/mingju\/juv_694a42b11027.aspx"
    },
    {
      "sentence": "万一禅关砉然破，美人如玉剑如虹。",
      "source": "龚自珍《夜坐二首》",
      "href": "\/mingju\/juv_287e2a927c7c.aspx"
    },
    {
      "sentence": "朝饮木兰之坠露兮，夕餐秋菊之落英。",
      "source": "屈原《离骚》",
      "href": "\/mingju\/juv_60ca5b1a8939.aspx"
    },
    {
      "sentence": "一丘一壑也风流。",
      "source": "辛弃疾《鹧鸪天·鹅湖归病起作》",
      "href": "\/mingju\/juv_de8dbcc4f247.aspx"
    },
    {
      "sentence": "看花满眼泪，不共楚王言。",
      "source": "王维《息夫人》",
      "href": "\/mingju\/juv_3ff7809c09e6.aspx"
    },
    {
      "sentence": "丧虽有礼，而哀为本焉",
      "source": "《墨子·02章 修身》",
      "href": "\/mingju\/juv_fcf553f9d8c9.aspx"
    },
    {
      "sentence": "至今云雨带愁容，月斜江上，征棹动晨钟。",
      "source": "牛希济《临江仙·峭壁参差十二峰》",
      "href": "\/mingju\/juv_c5f787aa2e4e.aspx"
    },
    {
      "sentence": "白云海色曙，明月天门秋。",
      "source": "王世贞《登太白楼》",
      "href": "\/mingju\/juv_0b78fcfc94ca.aspx"
    },
    {
      "sentence": "南阜小亭台，薄有山花取次开。",
      "source": "虞集《南乡一剪梅·招熊少府》",
      "href": "\/mingju\/juv_eb635c0ae394.aspx"
    },
    {
      "sentence": "春色浮寒瓮，吸海垂虹。",
      "source": "贺铸《六州歌头·少年侠气》",
      "href": "\/mingju\/juv_d98e827460ca.aspx"
    },
    {
      "sentence": "自伯之东，首如飞蓬。岂无膏沐，谁适为容？",
      "source": "佚名《伯兮》",
      "href": "\/mingju\/juv_5d34279bf4da.aspx"
    },
    {
      "sentence": "天下有非望之福，亦有非望之祸。",
      "source": "《郁离子·卷四》",
      "href": "\/mingju\/juv_f7e36e90d5e5.aspx"
    },
    {
      "sentence": "时未至而为之，谓之躁；时至而不为之，谓之陋。",
      "source": "《郁离子·卷五》",
      "href": "\/mingju\/juv_321ba1506225.aspx"
    },
    {
      "sentence": "蓝田曾种玉，红叶自题诗。",
      "source": "",
      "href": "\/mingju\/juv_ca03e0628373.aspx"
    },
    {
      "sentence": "立诚，自不妄语始",
      "source": "《明儒学案·蕺山学案·忠端刘念台先生宗周第一百九十八》",
      "href": "\/mingju\/juv_de9eda0c55d8.aspx"
    },
    {
      "sentence": "长随君，君入楚山里，云亦随君渡湘水。",
      "source": "李白《白云歌送刘十六归山》",
      "href": "\/mingju\/juv_383ea622f44a.aspx"
    },
    {
      "sentence": "相鼠有齿，人而无止！",
      "source": "佚名《国风·鄘风·相鼠》",
      "href": "\/mingju\/juv_7722a7585591.aspx"
    },
    {
      "sentence": "七月半，秉烛烧香问苍天，六月三伏天，人人摇扇我心寒。",
      "source": "卓文君《怨郎诗》",
      "href": "\/mingju\/juv_4009489480a0.aspx"
    },
    {
      "sentence": "国破山河落照红。",
      "source": "朱敦儒《减字木兰花·刘郎已老》",
      "href": "\/mingju\/juv_fff732eae8be.aspx"
    },
    {
      "sentence": "境难足于心，尽行放下，则未有不足矣。",
      "source": "《围炉夜话·第一一三则》",
      "href": "\/mingju\/juv_4bc632b7b337.aspx"
    },
    {
      "sentence": "乡书不可寄，秋雁又南回。",
      "source": "韦庄《章台夜思》",
      "href": "\/mingju\/juv_1a3e66e36233.aspx"
    },
    {
      "sentence": "仓廪虚兮岁月乏，子孙愚兮礼仪疏。",
      "source": "《增广贤文·上集》",
      "href": "\/mingju\/juv_788c4151e133.aspx"
    },
    {
      "sentence": "春来秋去相思在，秋去春来信息违。",
      "source": "鱼玄机《闺怨》",
      "href": "\/mingju\/juv_bf09c1c820b7.aspx"
    },
    {
      "sentence": "人之生也，必以其欢。",
      "source": "《管子·内业》",
      "href": "\/mingju\/juv_900b5b6baa31.aspx"
    },
    {
      "sentence": "恨芳菲世界，游人未赏，都付与、莺和燕。",
      "source": "陈亮《水龙吟·春恨》",
      "href": "\/mingju\/juv_246c0b4233c1.aspx"
    },
    {
      "sentence": "易子而食之，析骸而炊之。",
      "source": "《公羊传·宣公·十五年》",
      "href": "\/mingju\/juv_07c6749c23d2.aspx"
    },
    {
      "sentence": "一生大笑能几回，斗酒相逢须醉倒。",
      "source": "岑参《凉州馆中与诸判官夜集》",
      "href": "\/mingju\/juv_aa74d055f80d.aspx"
    },
    {
      "sentence": "时运不齐，命途多舛。",
      "source": "王勃《滕王阁序》",
      "href": "\/mingju\/juv_1215fafc845b.aspx"
    },
    {
      "sentence": "愁心视春草，畏向阶前生。",
      "source": "王维《杂诗三首 \/ 杂咏三首》",
      "href": "\/mingju\/juv_f5dbac64905e.aspx"
    },
    {
      "sentence": "众鸟高飞尽，孤云独去闲。",
      "source": "李白《独坐敬亭山》",
      "href": "\/mingju\/juv_1aba6694d69b.aspx"
    },
    {
      "sentence": "自奉必须俭约，宴客切勿流连。",
      "source": "《朱子家训·全文》",
      "href": "\/mingju\/juv_c50ad5472d38.aspx"
    },
    {
      "sentence": "钟期久已没，世上无知音。",
      "source": "李白《月夜听卢子顺弹琴》",
      "href": "\/mingju\/juv_fd2d752fde49.aspx"
    },
    {
      "sentence": "九重城阙烟尘生，千乘万骑西南行。",
      "source": "白居易《长恨歌》",
      "href": "\/mingju\/juv_0f38a96c0f4d.aspx"
    },
    {
      "sentence": "今岁花时深院，尽日东风，荡扬茶烟。",
      "source": "苏轼《雨中花·夜行船》",
      "href": "\/mingju\/juv_0242cc9a0f8d.aspx"
    },
    {
      "sentence": "君不见左纳言，右纳史，朝承恩，暮赐死。",
      "source": "白居易《太行路》",
      "href": "\/mingju\/juv_b6820e380f09.aspx"
    },
    {
      "sentence": "天苍苍，野茫茫，风吹草低见牛羊。",
      "source": "佚名《敕勒歌》",
      "href": "\/mingju\/juv_a8df73134d6a.aspx"
    },
    {
      "sentence": "闻善以相告也，见善以相示也",
      "source": "《礼记·儒行》",
      "href": "\/mingju\/juv_7db48fe5b4ae.aspx"
    },
    {
      "sentence": "嬉笑之怒，甚于裂眦；长歌之哀，过于恸哭。",
      "source": "《容斋随笔·卷二·长歌之哀》",
      "href": "\/mingju\/juv_d46e06a24625.aspx"
    },
    {
      "sentence": "天秋木叶下，月冷莎鸡悲。",
      "source": "李白《秋思》",
      "href": "\/mingju\/juv_4e4283c37473.aspx"
    },
    {
      "sentence": "芳菲歇去何须恨，夏木阴阴正可人。",
      "source": "秦观《三月晦日偶题》",
      "href": "\/mingju\/juv_dbe31b1b8d86.aspx"
    },
    {
      "sentence": "穷且益坚，不坠青云之志。",
      "source": "王勃《滕王阁序》",
      "href": "\/mingju\/juv_8303185b71f4.aspx"
    },
    {
      "sentence": "君子之道，暗然而日章；小人之道，的然而日亡。",
      "source": "《中庸·第三十三章》",
      "href": "\/mingju\/juv_3e9681279c38.aspx"
    },
    {
      "sentence": "不以无过为贤，而以改过为美也。",
      "source": "《资治通鉴·汉纪·汉纪四》",
      "href": "\/mingju\/juv_ba2f5c251f2e.aspx"
    },
    {
      "sentence": "旱则资舟，水则资车，以待乏也。",
      "source": "《国语·越语·勾践灭吴》",
      "href": "\/mingju\/juv_7bd61dde2948.aspx"
    },
    {
      "sentence": "谁在玉关劳苦？谁在玉楼歌舞？",
      "source": "李好古《谒金门·花过雨》",
      "href": "\/mingju\/juv_a72293f8d82b.aspx"
    },
    {
      "sentence": "藏世界于一粟，佛法何其大；贮乾坤于一壶，道法何其玄。",
      "source": "《幼学琼林·卷四·释道鬼神》",
      "href": "\/mingju\/juv_88df7a004813.aspx"
    },
    {
      "sentence": "东都妙姬，南国佳人，蕙心纨质，玉貌绛唇，莫不埋魂幽石，委骨穷尘。",
      "source": "鲍照《芜城赋》",
      "href": "\/mingju\/juv_20e41f7d6516.aspx"
    },
    {
      "sentence": "点到为止，见好就收。",
      "source": "",
      "href": "\/mingju\/juv_5e6acd05b313.aspx"
    },
    {
      "sentence": "希圣如有立，绝笔于获麟。",
      "source": "李白《古风·大雅久不作》",
      "href": "\/mingju\/juv_5c9c50fefa4d.aspx"
    },
    {
      "sentence": "尽是刘郎去后栽。",
      "source": "苏轼《南乡子·席上劝李公择酒》",
      "href": "\/mingju\/juv_0641591a7752.aspx"
    },
    {
      "sentence": "桃花落处无人见，濯手惟闻涧水香。",
      "source": "黄公度《暮春山间》",
      "href": "\/mingju\/juv_c93bef9622ee.aspx"
    },
    {
      "sentence": "在昔无酒饮，今但湛空觞。",
      "source": "陶渊明《拟挽歌辞三首》",
      "href": "\/mingju\/juv_dcc5451d8ffd.aspx"
    },
    {
      "sentence": "学之染人，甚于丹青。",
      "source": "《晋书·列传·第五十二章》",
      "href": "\/mingju\/juv_6e02c4b09fd6.aspx"
    },
    {
      "sentence": "茫茫江汉上，日暮欲何之。",
      "source": "刘长卿《送李中丞之襄州 \/ 送李中丞归汉阳别业》",
      "href": "\/mingju\/juv_a14c581c45fb.aspx"
    },
    {
      "sentence": "开门复动竹，疑是故人来。",
      "source": "李益《竹窗闻风寄苗发司空曙》",
      "href": "\/mingju\/juv_fee8ef211b6c.aspx"
    },
    {
      "sentence": "虎豹不外其爪。",
      "source": "",
      "href": "\/mingju\/juv_3c1fa81935ac.aspx"
    },
    {
      "sentence": "孔子登东山而小鲁，登泰山而小天下。",
      "source": "《孟子·尽心章句上·第二十四节》",
      "href": "\/mingju\/juv_bd17ad353efd.aspx"
    },
    {
      "sentence": "龙旂阳阳，和铃央央。",
      "source": "佚名《周颂·载见》",
      "href": "\/mingju\/juv_b5d68241ee7d.aspx"
    },
    {
      "sentence": "莲叶初生南浦，两岸绿杨飞絮。",
      "source": "贺铸《忆仙姿·莲叶初生南浦》",
      "href": "\/mingju\/juv_bf50d161e04d.aspx"
    },
    {
      "sentence": "仁则荣，不仁则辱。今恶辱而居不仁，是犹恶湿而居下也。",
      "source": "《孟子·公孙丑章句上·第四节》",
      "href": "\/mingju\/juv_2ad77f955376.aspx"
    },
    {
      "sentence": "识者以谓合住一言，贤于数十万兵。",
      "source": "《辽史·列传·卷十六》",
      "href": "\/mingju\/juv_bc103529da5b.aspx"
    },
    {
      "sentence": "有不忍言之心，必有不忍言之祸。",
      "source": "《围炉夜话·第一三Ｏ则》",
      "href": "\/mingju\/juv_2cdcb886ba0b.aspx"
    },
    {
      "sentence": "天下者非一人之天下，唯有道者处之。",
      "source": "《六韬·武韬·顺启》",
      "href": "\/mingju\/juv_8625dc28ba79.aspx"
    },
    {
      "sentence": "玉树歌残迹已陈，南朝宫殿柳条新。",
      "source": "陈于王《题桃花扇传奇》",
      "href": "\/mingju\/juv_98983a83176d.aspx"
    },
    {
      "sentence": "驱驱行役，苒苒光阴，蝇头利禄，蜗角功名，毕竟成何事，漫相高。",
      "source": "柳永《凤归云·向深秋》",
      "href": "\/mingju\/juv_bc9a66af977b.aspx"
    },
    {
      "sentence": "多能者鲜精，多虑者鲜决。",
      "source": "《郁离子·卷三》",
      "href": "\/mingju\/juv_f73742dde0ed.aspx"
    },
    {
      "sentence": "尔来从军天汉滨，南山晓雪玉嶙峋。",
      "source": "陆游《金错刀行》",
      "href": "\/mingju\/juv_9114e5de0f79.aspx"
    },
    {
      "sentence": "衡阳犹有雁传书。郴阳和雁无。",
      "source": "秦观《阮郎归·湘天风雨破寒初》",
      "href": "\/mingju\/juv_80415e4184d4.aspx"
    },
    {
      "sentence": "人所易言，我寡言之；人所难言，我易言之：诗便不俗。",
      "source": "《随园诗话·卷四》",
      "href": "\/mingju\/juv_86e172a8d4d0.aspx"
    },
    {
      "sentence": "八年十二月，五日雪纷纷。",
      "source": "白居易《村居苦寒》",
      "href": "\/mingju\/juv_8f80ba6d294e.aspx"
    },
    {
      "sentence": "兰之猗猗，扬扬其香。",
      "source": "韩愈《猗兰操》",
      "href": "\/mingju\/juv_04525eeb22af.aspx"
    },
    {
      "sentence": "腰中双绮带，梦为同心结。",
      "source": "萧衍《有所思》",
      "href": "\/mingju\/juv_c8218be071d5.aspx"
    },
    {
      "sentence": "菩萨妖精，总是一念。若论本来，皆属无有。",
      "source": "《西游记·第十七回》",
      "href": "\/mingju\/juv_ae983fc1ed86.aspx"
    },
    {
      "sentence": "以众人之力起事者，无不成也。",
      "source": "《管子·形势解》",
      "href": "\/mingju\/juv_30c3e6d6ab30.aspx"
    },
    {
      "sentence": "礼无不答。",
      "source": "《资治通鉴·汉纪·汉纪三十六》",
      "href": "\/mingju\/juv_197e63b7a28b.aspx"
    },
    {
      "sentence": "唤起思量，待不思量，怎不思量！",
      "source": "郑光祖《蟾宫曲·梦中作》",
      "href": "\/mingju\/juv_6597356d3b77.aspx"
    },
    {
      "sentence": "四十三年，望中犹记，烽火扬州路。",
      "source": "辛弃疾《永遇乐·京口北固亭怀古》",
      "href": "\/mingju\/juv_3010e1b07488.aspx"
    },
    {
      "sentence": "不似秋光，只与离人照断肠。",
      "source": "苏轼《减字木兰花·春月》",
      "href": "\/mingju\/juv_5aa093b18c42.aspx"
    },
    {
      "sentence": "且趁闲身未老，尽放我、些子疏狂。",
      "source": "苏轼《满庭芳·蜗角虚名》",
      "href": "\/mingju\/juv_b6acc2297a02.aspx"
    },
    {
      "sentence": "乐极生悲，否极泰来。",
      "source": "《水浒传·第二十六回》",
      "href": "\/mingju\/juv_6fd4167b7c5f.aspx"
    },
    {
      "sentence": "八月湖水平，涵虚混太清。",
      "source": "孟浩然《望洞庭湖赠张丞相 \/ 临洞庭》",
      "href": "\/mingju\/juv_8dc21599c021.aspx"
    },
    {
      "sentence": "深知身在情长在，怅望江头江水声。",
      "source": "李商隐《暮秋独游曲江》",
      "href": "\/mingju\/juv_d9d727592274.aspx"
    },
    {
      "sentence": "十年寒窗无人问，一举成名天下知。",
      "source": "《增广贤文·上集》",
      "href": "\/mingju\/juv_56cd8fe503c4.aspx"
    },
    {
      "sentence": "直至如今千载后，谁与争功！",
      "source": "王安石《浪淘沙令·伊吕两衰翁》",
      "href": "\/mingju\/juv_8baaa8db1750.aspx"
    },
    {
      "sentence": "阿香秋梦起娇啼，玉女传幽素。",
      "source": "吴文英《烛影摇红·越上霖雨应祷》",
      "href": "\/mingju\/juv_83ec0778ef8b.aspx"
    },
    {
      "sentence": "儒有不宝金玉，而忠信以为宝",
      "source": "《礼记·儒行》",
      "href": "\/mingju\/juv_ba1b581ec21d.aspx"
    },
    {
      "sentence": "理财常以养民为先。",
      "source": "《资治通鉴·唐纪·唐纪四十二》",
      "href": "\/mingju\/juv_45d22f52e490.aspx"
    },
    {
      "sentence": "武安有振瓦，易水无寒歌。",
      "source": "李白《发白马》",
      "href": "\/mingju\/juv_e388e81d11d9.aspx"
    },
    {
      "sentence": "清浅白石滩，绿蒲向堪把。",
      "source": "王维《白石滩》",
      "href": "\/mingju\/juv_2f6a7dd1c632.aspx"
    },
    {
      "sentence": "心之官则思，思则得之，不思则不得也。",
      "source": "《孟子·告子章句上·第十五节》",
      "href": "\/mingju\/juv_179c80e335df.aspx"
    },
    {
      "sentence": "新秋至，人乍别，顺长江水流残月。",
      "source": "贯云石《寿阳曲·新秋至》",
      "href": "\/mingju\/juv_3f26d5bb5d6e.aspx"
    },
    {
      "sentence": "夕阳度西岭，群壑倏已暝。",
      "source": "孟浩然《宿业师山房期丁大不至 \/ 宿业师山房待丁大不至》",
      "href": "\/mingju\/juv_e5fe89f0bd27.aspx"
    },
    {
      "sentence": "得时者昌，失时者亡。",
      "source": "《列子·说符》",
      "href": "\/mingju\/juv_c4b8c77043fc.aspx"
    },
    {
      "sentence": "大功之后，逸乐易生",
      "source": "《新唐书·列传·卷一百零二》",
      "href": "\/mingju\/juv_5158d3c5f66d.aspx"
    },
    {
      "sentence": "天地交而万物通也，上下交而其志同也。",
      "source": "《易传·彖传上·泰》",
      "href": "\/mingju\/juv_3945d2acfd49.aspx"
    },
    {
      "sentence": "劝君看取利名场。今古梦茫茫。",
      "source": "晏殊《喜迁莺·花不尽》",
      "href": "\/mingju\/juv_ad5ea7c73286.aspx"
    },
    {
      "sentence": "暗暗淡淡紫，融融冶冶黄。",
      "source": "李商隐《菊花》",
      "href": "\/mingju\/juv_bdbb643e21b3.aspx"
    },
    {
      "sentence": "辞主乎达，不论其繁与简也，繁简之论兴，而文亡矣",
      "source": "《日知录·卷十九》",
      "href": "\/mingju\/juv_14bcd1013dce.aspx"
    },
    {
      "sentence": "千日行善，善犹不足；一日行恶，恶自有余。",
      "source": "《西游记·第二十八回》",
      "href": "\/mingju\/juv_45c252af5c93.aspx"
    },
    {
      "sentence": "世道剧颓波，我心如砥柱。",
      "source": "刘禹锡《咏史二首》",
      "href": "\/mingju\/juv_f6dfacf2425e.aspx"
    },
    {
      "sentence": "持志如心痛。",
      "source": "《传习录·卷上·门人薛侃录》",
      "href": "\/mingju\/juv_808702be0142.aspx"
    },
    {
      "sentence": "三杯拂剑舞秋月，忽然高咏涕泗涟。",
      "source": "李白《玉壶吟》",
      "href": "\/mingju\/juv_83482dacdcf4.aspx"
    },
    {
      "sentence": "库无备兵，虽有义，不能征无义",
      "source": "《墨子·05章 七患》",
      "href": "\/mingju\/juv_e83fb03646f5.aspx"
    },
    {
      "sentence": "风烟并起思归望，远目非春亦自伤。",
      "source": "李益《同崔邠登鹳雀楼》",
      "href": "\/mingju\/juv_5eab942a49f1.aspx"
    },
    {
      "sentence": "写不了相思，又蘸凉波飞去。",
      "source": "朱彝尊《长亭怨慢·雁》",
      "href": "\/mingju\/juv_e22ab1b03d3a.aspx"
    },
    {
      "sentence": "管甚有监州，不可无螃蟹。",
      "source": "薛昂夫《庆东原·西皋亭适兴》",
      "href": "\/mingju\/juv_d8119a2d9c21.aspx"
    },
    {
      "sentence": "悠悠慈母心，惟愿才如人。",
      "source": "鲍溶《将归旧山留别孟郊》",
      "href": "\/mingju\/juv_09f17fbdc7ac.aspx"
    },
    {
      "sentence": "华清妃子浴，绰约美人妆。",
      "source": "",
      "href": "\/mingju\/juv_4ced36d5833d.aspx"
    },
    {
      "sentence": "三百年来伤国步，八千里外吊民残。",
      "source": "李鸿章《临终诗》",
      "href": "\/mingju\/juv_eab48641d9a7.aspx"
    },
    {
      "sentence": "机中锦字论长恨，楼上花枝笑独眠。",
      "source": "皇甫冉《春思》",
      "href": "\/mingju\/juv_738840b0c28e.aspx"
    },
    {
      "sentence": "清风明月好时光。",
      "source": "晏殊《燕归梁·双燕归飞绕画堂》",
      "href": "\/mingju\/juv_421520ee2a42.aspx"
    },
    {
      "sentence": "意气骄满路，鞍马光照尘。",
      "source": "白居易《轻肥》",
      "href": "\/mingju\/juv_459344c1a998.aspx"
    },
    {
      "sentence": "等是有家归未得，杜鹃休向耳边啼。",
      "source": "佚名《杂诗》",
      "href": "\/mingju\/juv_b5c0eb9a4241.aspx"
    },
    {
      "sentence": "萤火而今，飞破秋夕。",
      "source": "张先《惜琼花·汀苹白》",
      "href": "\/mingju\/juv_7077d85f71d1.aspx"
    },
    {
      "sentence": "少成若天性，习惯如自然。",
      "source": "《汉书·传·贾谊传》",
      "href": "\/mingju\/juv_42b06e776f40.aspx"
    },
    {
      "sentence": "轻舟泛月寻溪转，疑是山阴雪后来。",
      "source": "李白《东鲁门泛舟二首》",
      "href": "\/mingju\/juv_136b439ee153.aspx"
    },
    {
      "sentence": "当初不合种相思。",
      "source": "姜夔《鹧鸪天·元夕有所梦》",
      "href": "\/mingju\/juv_3c5240b8c756.aspx"
    },
    {
      "sentence": "水通南国三千里，气压江城十四州。",
      "source": "李清照《题八咏楼》",
      "href": "\/mingju\/juv_f69b0f2a795c.aspx"
    },
    {
      "sentence": "只愁歌舞散，化作彩云飞。",
      "source": "李白《宫中行乐词八首》",
      "href": "\/mingju\/juv_81185db9937f.aspx"
    },
    {
      "sentence": "古往今来共一时，人生万事无不有。",
      "source": "杜甫《可叹》",
      "href": "\/mingju\/juv_ae05aa5528a1.aspx"
    },
    {
      "sentence": "去年相送，余杭门外，飞雪似杨花。",
      "source": "苏轼《少年游·润州作》",
      "href": "\/mingju\/juv_36008950fb05.aspx"
    },
    {
      "sentence": "细雨骑驴入剑门。",
      "source": "陆游《剑门道中遇微雨》",
      "href": "\/mingju\/juv_e03b2618ff00.aspx"
    },
    {
      "sentence": "须知今古事，棋枰胜负，翻覆如斯。",
      "source": "纳兰性德《满庭芳·堠雪翻鸦》",
      "href": "\/mingju\/juv_f2820c1a8f71.aspx"
    },
    {
      "sentence": "谁家吹笛画楼中？断续声随断续风。",
      "source": "赵嘏《闻笛》",
      "href": "\/mingju\/juv_1bef009d6c42.aspx"
    },
    {
      "sentence": "登高壮观天地间，大江茫茫去不还。",
      "source": "李白《庐山谣寄卢侍御虚舟》",
      "href": "\/mingju\/juv_5b7e24ebe03e.aspx"
    },
    {
      "sentence": "长条短叶翠濛濛，才过西风，又过东风。",
      "source": "夏完淳《一剪梅·咏柳》",
      "href": "\/mingju\/juv_92c0a4c89038.aspx"
    },
    {
      "sentence": "惊雷势欲拨三山，急雨声如倒百川。",
      "source": "洪炎《次韵公实雷雨》",
      "href": "\/mingju\/juv_2c3e0638022b.aspx"
    },
    {
      "sentence": "无人赏高节，徒自抱贞心。",
      "source": "刘孝先《咏竹》",
      "href": "\/mingju\/juv_caf1a498972d.aspx"
    },
    {
      "sentence": "败子回头便作家。",
      "source": "《醒世恒言·卷十七》",
      "href": "\/mingju\/juv_c99de6e5f052.aspx"
    },
    {
      "sentence": "反水不收，后悔无及。",
      "source": "《后汉书·本纪·光武帝纪上》",
      "href": "\/mingju\/juv_221739d80a39.aspx"
    },
    {
      "sentence": "君子先择而后交，小人先交而后择。",
      "source": "",
      "href": "\/mingju\/juv_a0394b8d8cf6.aspx"
    },
    {
      "sentence": "所志在功名，离别何足叹。",
      "source": "陆龟蒙《别离》",
      "href": "\/mingju\/juv_feb16bf1826a.aspx"
    },
    {
      "sentence": "万两黄金容易得，知心一个也难求",
      "source": "《红楼梦·第五十七回》",
      "href": "\/mingju\/juv_93767ac8bd64.aspx"
    },
    {
      "sentence": "气软来风易，枝繁度鸟迟。",
      "source": "李爽《芳树》",
      "href": "\/mingju\/juv_208f14d3c809.aspx"
    },
    {
      "sentence": "一团团、逐队成毬。",
      "source": "曹雪芹《唐多令·柳絮》",
      "href": "\/mingju\/juv_650173ff25c4.aspx"
    },
    {
      "sentence": "魏王贻我大瓠之种，我树之成而实五石。",
      "source": "佚名《大瓠之种》",
      "href": "\/mingju\/juv_e0c256d1a0ed.aspx"
    },
    {
      "sentence": "不自是而露才，不轻试以显功。",
      "source": "",
      "href": "\/mingju\/juv_c8f036360c26.aspx"
    },
    {
      "sentence": "茂陵多病后，尚爱卓文君。",
      "source": "杜甫《琴台》",
      "href": "\/mingju\/juv_c85aa83072b2.aspx"
    },
    {
      "sentence": "采之欲遗谁？所思在远道。",
      "source": "佚名《涉江采芙蓉》",
      "href": "\/mingju\/juv_8878cdda2f10.aspx"
    },
    {
      "sentence": "蜂蝶去纷纷，香风隔岸闻。",
      "source": "韩愈《花岛》",
      "href": "\/mingju\/juv_9606f6563a75.aspx"
    },
    {
      "sentence": "寒山吹笛唤春归，迁客相看泪满衣。",
      "source": "李益《春夜闻笛》",
      "href": "\/mingju\/juv_d3cc5c8ab2d4.aspx"
    },
    {
      "sentence": "洗尽古今人不倦，将知醉后岂堪夸。",
      "source": "元稹《一七令·茶》",
      "href": "\/mingju\/juv_47e33c395cb9.aspx"
    },
    {
      "sentence": "无论海角与天涯，大抵心安即是家。",
      "source": "白居易《种桃杏》",
      "href": "\/mingju\/juv_df47c6805769.aspx"
    },
    {
      "sentence": "灰宿温瓶火，香添暖被笼。",
      "source": "白居易《秋雨夜眠》",
      "href": "\/mingju\/juv_27d45646f3fd.aspx"
    },
    {
      "sentence": "愁闻出塞曲，泪满逐臣缨。",
      "source": "李白《观胡人吹笛》",
      "href": "\/mingju\/juv_90ccca0b1dac.aspx"
    },
    {
      "sentence": "策我良马，被我轻裘。",
      "source": "曹丕《善哉行·其一》",
      "href": "\/mingju\/juv_fdd827f3270c.aspx"
    },
    {
      "sentence": "谁家秋院无风入？何处秋窗无雨声？",
      "source": "曹雪芹《代别离·秋窗风雨夕》",
      "href": "\/mingju\/juv_5e131dd10a17.aspx"
    },
    {
      "sentence": "门内有君子，门外君子至。",
      "source": "《警世通言·卷一》",
      "href": "\/mingju\/juv_e51f410a92a0.aspx"
    },
    {
      "sentence": "笔头风月时时过，眼底儿曹渐渐多。",
      "source": "姚燧《阳春曲·笔头风月时时过》",
      "href": "\/mingju\/juv_7b7fb618cb93.aspx"
    },
    {
      "sentence": "俯仰终宇宙，不乐复何如？",
      "source": "陶渊明《读山海经·其一》",
      "href": "\/mingju\/juv_a9df40ad8843.aspx"
    },
    {
      "sentence": "自古功名属少年。",
      "source": "陆游《长相思·面苍然》",
      "href": "\/mingju\/juv_f7d72102cbd4.aspx"
    },
    {
      "sentence": "半夜一声长啸，悲天地、为予窄。",
      "source": "辛弃疾《霜天晓角·赤壁》",
      "href": "\/mingju\/juv_896af157302d.aspx"
    },
    {
      "sentence": "知足者富。",
      "source": "《老子·道经·第三十三章》",
      "href": "\/mingju\/juv_a44f38c60bad.aspx"
    },
    {
      "sentence": "春水无风无浪，春天半雨半晴。",
      "source": "和凝《春光好·蘋叶软》",
      "href": "\/mingju\/juv_22c24bd96d3c.aspx"
    }
  ]
}